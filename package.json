{
  "name": "@git-lfs-hub/lib",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    "./auth": "./src/auth/index.ts",
    "./auth/session": "./src/auth/session.ts",
    "./github": "./src/github/index.ts"
    "./github": "./src/github/index.ts",
    "./contracts": "./src/contracts/index.ts"
  },
  "scripts": {
    "compile": "tsgo --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "check": "bun run compile && bun run lint && bun run format:check",
    "vitest": "bun run check && bunx vitest",
    "test": "bun run vitest run",
    "test-coverage": "bun run test --coverage"
  },
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": "^26.1.0"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "hono": "^4.12.23",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@typescript/native-preview": "^7.0.0-dev.20260606.1",
    "@vitest/coverage-istanbul": "^4.1.8",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "vitest": "^4.1.8"
  }
}
